# ==========================================
# WATCHLIST API KEYS
# ==========================================
# Copy this file to .env (or server/.env) and add your keys
#
# Get OMDB key at: https://www.omdbapi.com/apikey.aspx
# Get TMDB key at: https://www.themoviedb.org/settings/api
# ==========================================

OMDB_API_KEY=your_omdb_api_key_here
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: cloud sync so each ?p=profile list is stored on the server (share with partner)
# Create a free project at https://supabase.com → SQL Editor → run README.sql snippet
# Project Settings → API → copy URL and service_role secret (server only, never in the browser)
# Project URL: Settings → General ("Project URL") or Connect dialog — https://xxxxx.supabase.co
SUPABASE_URL=https://xxxx.supabase.co
# New dashboard: "Secret key" (sb_secret_...). Legacy: "service_role" JWT. Either works:
SUPABASE_SERVICE_ROLE_KEY=your_secret_or_service_role_key_here
# Optional alias (same value as above):
# SUPABASE_SECRET_KEY=sb_secret_xxxxx

# Slug for the shared “Watch together” playlist (one row in Supabase). Don’t use this as a personal ?p= profile.
# SHARED_LIST_SLUG=watch-together

# --- Vercel ---
# Add the same variables in the Vercel dashboard (Project → Settings → Environment Variables).
# Local server/.env is NOT uploaded; without dashboard vars, hasCloudSync stays false on production.

# --- Optional: private deployment (small trusted group) ---
# When set, visitors must open /gate.html and enter this password once per browser (HTTP-only cookie).
# Share the password only with people you trust. Rotate it to revoke everyone at once.
# PRIVATE_SITE_PASSWORD=your-long-random-shared-password
# Optional: separate secret for signing cookies (recommended in production). If omitted, a key is derived from the password.
# SITE_AUTH_SECRET=another-long-random-string
